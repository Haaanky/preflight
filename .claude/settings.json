{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "allowedTools": [
    "Read",
    "Glob",
    "Grep",
    "Task"
  ],

  "denyTools": [],

  "hooks": {

    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],

    "PreToolCall": [
      {
        "matcher": "git commit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]

  }
}
